{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": ".",
		"target": "ES2024",
		"module": "nodenext",
		"moduleResolution": "nodenext"
	},
	"include": ["src/**/*", "schema/**/*"],
	"exclude": ["**/*.test.ts", "migrations/**", "drizzle.config.ts"]
}
