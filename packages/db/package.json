{
	"name": "@nexo/db",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"db:generate": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit generate",
		"db:migrate": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit migrate",
		"db:studio": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit studio",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"knip": "knip",
		"package:check": "sort-package-json --check",
		"package:format": "sort-package-json",
		"qc": "run-s package:check format:check knip type:check",
		"type:check": "tsc --noEmit"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@types/node": "^22.19.17",
		"dotenv-cli": "^8.0.0",
		"drizzle-kit": "^0.31.10",
		"knip": "^6.12.1",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.3",
		"sort-package-json": "^3.6.1",
		"typescript": "^6.0.3"
	}
}
