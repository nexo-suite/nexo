{
	"name": "@nexo/db",
	"version": "0.10.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"package.json"
	],
	"scripts": {
		"build": "tsdown && cp -r migrations dist/migrations",
		"clean": "del dist",
		"db:generate": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit generate",
		"db:migrate": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit migrate",
		"db:studio": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit studio",
		"qc": "run-s type:check build",
		"type:check": "tsgo --noEmit"
	},
	"dependencies": {
		"drizzle-orm": "catalog:",
		"postgres": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10"
	}
}
