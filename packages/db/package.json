{
	"name": "@nexo/db",
	"version": "0.2.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"db:generate": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit generate",
		"db:migrate": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit migrate",
		"db:studio": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit studio",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"qc": "run-s lint type:check",
		"type:check": "tsc --noEmit"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"dotenv-cli": "^8.0.0",
		"drizzle-kit": "^0.31.10"
	}
}
