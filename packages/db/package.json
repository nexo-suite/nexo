{
	"name": "@nexo/db",
	"version": "0.5.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/src/index.d.ts",
			"default": "./dist/src/index.js"
		}
	},
	"files": [
		"dist",
		"package.json"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist",
		"db:generate": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit generate",
		"db:migrate": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit migrate",
		"db:studio": "dotenv -e ../../.env.local -e ../../.env -- drizzle-kit studio",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"qc": "run-s lint type:check build",
		"type:check": "tsc --noEmit"
	},
	"dependencies": {
		"drizzle-orm": "catalog:",
		"postgres": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10"
	}
}
