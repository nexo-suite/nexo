{
	"name": "@nexo/push",
	"version": "0.3.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./schema": {
			"types": "./dist/schema.d.ts",
			"default": "./dist/schema.js"
		},
		"./server": {
			"types": "./dist/server.d.ts",
			"default": "./dist/server.js"
		},
		"./routes": {
			"types": "./dist/routes.d.ts",
			"default": "./dist/routes.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"default": "./dist/client.js"
		},
		"./sw": {
			"types": "./dist/sw.d.ts",
			"default": "./dist/sw.js"
		}
	},
	"files": [
		"dist",
		"package.json"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"qc": "run-s lint type:check build",
		"type:check": "tsc --noEmit"
	},
	"dependencies": {
		"@nexo/db": "workspace:*",
		"@nexo/logger": "workspace:*",
		"drizzle-orm": "catalog:",
		"web-push": "catalog:"
	},
	"devDependencies": {
		"@sveltejs/kit": "catalog:",
		"@types/node": "catalog:",
		"@types/web-push": "catalog:"
	}
}
