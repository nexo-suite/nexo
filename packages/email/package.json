{
	"name": "@nexo/email",
	"version": "0.2.1",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"package.json"
	],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"clean": "rm -rf dist",
		"dev": "email dev --dir src/templates --port 3005",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"qc": "run-s lint type:check build",
		"type:check": "tsc --noEmit"
	},
	"dependencies": {
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-email": "^6.1.5",
		"resend": "^6.12.3"
	},
	"devDependencies": {
		"@react-email/ui": "^6.1.5",
		"@types/node": "catalog:",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3"
	}
}
