{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"target": "ES2024",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"jsx": "react-jsx"
	},
	"include": ["src/**/*"],
	"exclude": ["**/*.test.ts"]
}
