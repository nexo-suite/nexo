{
	"uid": "nexo-stack",
	"title": "Nexo · Stack Overview",
	"tags": ["nexo", "overview"],
	"timezone": "browser",
	"editable": false,
	"schemaVersion": 39,
	"version": 1,
	"refresh": "30s",
	"time": { "from": "now-1h", "to": "now" },
	"templating": { "list": [] },
	"panels": [
		{
			"id": 1,
			"type": "stat",
			"title": "Running containers",
			"gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{ "expr": "count(count by (name) (container_last_seen{name=~\"nexo-.+\"}))", "refId": "A" }
			],
			"options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "thresholds" },
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "red", "value": null },
							{ "color": "green", "value": 8 }
						]
					}
				}
			}
		},
		{
			"id": 2,
			"type": "gauge",
			"title": "Host RAM used",
			"gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 70 },
							{ "color": "red", "value": 90 }
						]
					}
				}
			}
		},
		{
			"id": 3,
			"type": "gauge",
			"title": "Host disk used (/)",
			"gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"expr": "(1 - node_filesystem_avail_bytes{mountpoint=\"/host\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{mountpoint=\"/host\",fstype!~\"tmpfs|overlay|squashfs\"}) * 100",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 75 },
							{ "color": "red", "value": 90 }
						]
					}
				}
			}
		},
		{
			"id": 4,
			"type": "gauge",
			"title": "Swap used",
			"gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"expr": "(node_memory_SwapTotal_bytes - node_memory_SwapFree_bytes) / node_memory_SwapTotal_bytes * 100",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"min": 0,
					"max": 100,
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 30 },
							{ "color": "red", "value": 60 }
						]
					}
				}
			}
		},
		{
			"id": 5,
			"type": "stat",
			"title": "PG connections",
			"gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [{ "expr": "sum(pg_stat_database_numbackends{datname=\"nexo\"})", "refId": "A" }],
			"options": { "colorMode": "value", "graphMode": "area", "textMode": "value_and_name" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "thresholds" },
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 50 },
							{ "color": "red", "value": 70 }
						]
					}
				}
			}
		},
		{
			"id": 6,
			"type": "timeseries",
			"title": "Container memory (working set)",
			"gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"expr": "container_memory_working_set_bytes{name=~\"nexo-.+\"}",
					"legendFormat": "{{name}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "bytes",
					"custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
				}
			},
			"options": {
				"legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
			}
		},
		{
			"id": 7,
			"type": "timeseries",
			"title": "Container CPU (%)",
			"gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"nexo-.+\"}[2m])) * 100",
					"legendFormat": "{{name}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
				}
			},
			"options": {
				"legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }
			}
		},
		{
			"id": 8,
			"type": "timeseries",
			"title": "Logs per minute by service",
			"gridPos": { "h": 9, "w": 12, "x": 0, "y": 13 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [
				{
					"expr": "sum by (service) (count_over_time({service=~\".+\"}[1m]))",
					"legendFormat": "{{service}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": { "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5 } }
			},
			"options": {
				"legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "sum"] }
			}
		},
		{
			"id": 9,
			"type": "timeseries",
			"title": "Errors per minute by service",
			"gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [
				{
					"expr": "sum by (service) (count_over_time({service=~\".+\", level=\"error\"}[1m]))",
					"legendFormat": "{{service}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 50 },
					"color": { "mode": "palette-classic" }
				}
			},
			"options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] } }
		},
		{
			"id": 10,
			"type": "logs",
			"title": "Recent errors (all services)",
			"gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [{ "expr": "{service=~\".+\", level=\"error\"}", "refId": "A" }],
			"options": {
				"showTime": true,
				"showLabels": false,
				"showCommonLabels": false,
				"wrapLogMessage": true,
				"dedupStrategy": "none",
				"sortOrder": "Descending"
			}
		}
	]
}
