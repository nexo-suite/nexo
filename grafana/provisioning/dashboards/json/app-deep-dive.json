{
	"uid": "nexo-app",
	"title": "Nexo · Per-App Deep Dive",
	"tags": ["nexo", "app"],
	"timezone": "browser",
	"editable": false,
	"schemaVersion": 39,
	"version": 1,
	"refresh": "30s",
	"time": { "from": "now-3h", "to": "now" },
	"templating": {
		"list": [
			{
				"name": "app",
				"label": "App",
				"type": "custom",
				"query": "finance,admin,flaschen,auth,landing,bot,flaschen-worker",
				"current": { "text": "finance", "value": "finance" },
				"options": [
					{ "text": "finance", "value": "finance", "selected": true },
					{ "text": "admin", "value": "admin", "selected": false },
					{ "text": "flaschen", "value": "flaschen", "selected": false },
					{ "text": "auth", "value": "auth", "selected": false },
					{ "text": "landing", "value": "landing", "selected": false },
					{ "text": "bot", "value": "bot", "selected": false },
					{ "text": "flaschen-worker", "value": "flaschen-worker", "selected": false }
				]
			}
		]
	},
	"panels": [
		{
			"id": 1,
			"type": "timeseries",
			"title": "Memory (working set)",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"expr": "container_memory_working_set_bytes{name=~\"nexo-${app}-.*\"}",
					"legendFormat": "{{name}}",
					"refId": "A"
				},
				{
					"expr": "container_spec_memory_limit_bytes{name=~\"nexo-${app}-.*\"}",
					"legendFormat": "{{name}} limit",
					"refId": "B"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "bytes",
					"custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
				},
				"overrides": [
					{
						"matcher": { "id": "byRegexp", "options": ".*limit.*" },
						"properties": [
							{ "id": "custom.lineStyle", "value": { "fill": "dash" } },
							{ "id": "custom.fillOpacity", "value": 0 }
						]
					}
				]
			}
		},
		{
			"id": 2,
			"type": "timeseries",
			"title": "CPU usage (%)",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
			"datasource": { "type": "prometheus", "uid": "prometheus" },
			"targets": [
				{
					"expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"nexo-${app}-.*\"}[2m])) * 100",
					"legendFormat": "{{name}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "percent",
					"custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
				}
			}
		},
		{
			"id": 3,
			"type": "timeseries",
			"title": "Request rate (Caddy)",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [
				{
					"expr": "sum by (status_class) (rate({service=\"caddy\"} | json | request_host=~\"${app}\\\\..+\" | label_format status_class=`{{ div .status 100 }}xx` [1m]))",
					"legendFormat": "{{status_class}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "reqps",
					"custom": {
						"drawStyle": "line",
						"lineWidth": 1,
						"fillOpacity": 30,
						"stacking": { "mode": "normal" }
					}
				}
			}
		},
		{
			"id": 4,
			"type": "timeseries",
			"title": "Latency p50 / p95 / p99 (Caddy)",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [
				{
					"expr": "quantile_over_time(0.50, {service=\"caddy\"} | json | request_host=~\"${app}\\\\..+\" | unwrap duration [2m])",
					"legendFormat": "p50",
					"refId": "A"
				},
				{
					"expr": "quantile_over_time(0.95, {service=\"caddy\"} | json | request_host=~\"${app}\\\\..+\" | unwrap duration [2m])",
					"legendFormat": "p95",
					"refId": "B"
				},
				{
					"expr": "quantile_over_time(0.99, {service=\"caddy\"} | json | request_host=~\"${app}\\\\..+\" | unwrap duration [2m])",
					"legendFormat": "p99",
					"refId": "C"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "s",
					"custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0 }
				}
			}
		},
		{
			"id": 5,
			"type": "timeseries",
			"title": "App log volume by level",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [
				{
					"expr": "sum by (level) (count_over_time({service=\"${app}\"}[1m]))",
					"legendFormat": "{{level}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"custom": {
						"drawStyle": "bars",
						"lineWidth": 1,
						"fillOpacity": 80,
						"stacking": { "mode": "normal" }
					}
				}
			}
		},
		{
			"id": 6,
			"type": "stat",
			"title": "Errors (1h)",
			"gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [
				{ "expr": "sum(count_over_time({service=\"${app}\", level=\"error\"}[1h]))", "refId": "A" }
			],
			"options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "thresholds" },
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 1 },
							{ "color": "red", "value": 10 }
						]
					}
				}
			}
		},
		{
			"id": 7,
			"type": "stat",
			"title": "5xx (1h, Caddy)",
			"gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [
				{
					"expr": "sum(count_over_time({service=\"caddy\"} | json | request_host=~\"${app}\\\\..+\" | status >= 500 [1h]))",
					"refId": "A"
				}
			],
			"options": { "colorMode": "background", "graphMode": "area", "textMode": "value" },
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "thresholds" },
					"thresholds": {
						"mode": "absolute",
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 1 },
							{ "color": "red", "value": 10 }
						]
					}
				}
			}
		},
		{
			"id": 8,
			"type": "logs",
			"title": "Recent errors",
			"gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
			"datasource": { "type": "loki", "uid": "loki" },
			"targets": [{ "expr": "{service=\"${app}\", level=\"error\"}", "refId": "A" }],
			"options": {
				"showTime": true,
				"showLabels": false,
				"wrapLogMessage": true,
				"dedupStrategy": "none",
				"sortOrder": "Descending"
			}
		}
	]
}
