{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":dependencyDashboard",
		":disableLockFileMaintenance",
		":semanticCommits",
		"helpers:pinGitHubActionDigests"
	],
	"timezone": "Europe/Berlin",
	"schedule": ["before 6am every weekday"],
	"labels": ["dependencies"],
	"commitMessagePrefix": "chore(deps):",
	"prConcurrentLimit": 10,
	"prHourlyLimit": 0,
	"minimumReleaseAge": "3 days",
	"osvVulnerabilityAlerts": true,
	"vulnerabilityAlerts": {
		"labels": ["security"],
		"minimumReleaseAge": "0 days",
		"schedule": ["at any time"]
	},
	"packageRules": [
		{
			"description": "SvelteKit ecosystem — always move together",
			"groupName": "SvelteKit ecosystem",
			"matchPackageNames": [
				"svelte",
				"svelte-check-native",
				"@sveltejs/kit",
				"@sveltejs/adapter-node",
				"@sveltejs/vite-plugin-svelte",
				"vite",
				"@vite-pwa/sveltekit",
				"vite-plugin-pwa",
				"workbox-precaching",
				"workbox-window"
			]
		},
		{
			"description": "Tailwind family",
			"groupName": "Tailwind",
			"matchPackageNames": ["tailwindcss", "@tailwindcss/vite", "tailwind-merge"]
		},
		{
			"description": "Drizzle monorepo",
			"groupName": "Drizzle",
			"matchPackageNames": ["drizzle-orm", "drizzle-kit"]
		},
		{
			"description": "Better Auth",
			"groupName": "Better Auth",
			"matchPackageNames": ["better-auth", "@better-auth/oauth-provider"]
		},
		{
			"description": "ESLint ecosystem",
			"groupName": "ESLint",
			"matchPackageNames": ["eslint", "@eslint/compat", "eslint-plugin-svelte", "typescript-eslint"]
		},
		{
			"description": "Testing stack",
			"groupName": "Testing",
			"matchPackageNames": [
				"vitest",
				"@vitest/coverage-v8",
				"@playwright/test",
				"@testing-library/jest-dom",
				"happy-dom"
			]
		},
		{
			"description": "Turborepo",
			"groupName": "Turborepo",
			"matchPackageNames": ["turbo"]
		},
		{
			"description": "Node.js runtime + types — single PR across .node-version, Dockerfiles, engines and @types/node",
			"groupName": "Node.js",
			"matchPackageNames": ["node", "@types/node"]
		},
		{
			"description": "Pin @types/node major to match the Node runtime — bump this constraint when the project moves to Node 25+",
			"matchPackageNames": ["@types/node"],
			"allowedVersions": "<25"
		},
		{
			"description": "Paraglide i18n",
			"groupName": "Paraglide",
			"matchPackageNames": ["@inlang/paraglide-js"]
		},
		{
			"description": "React Email — keep runtime, types and tooling in sync",
			"groupName": "React Email",
			"matchPackageNames": [
				"react",
				"react-dom",
				"@types/react",
				"@types/react-dom",
				"react-email",
				"@react-email/ui"
			]
		},
		{
			"description": "Build tools",
			"groupName": "Build tools",
			"matchPackageNames": ["tsx", "tsdown", "oxlint", "oxfmt", "@typescript/native-preview"]
		},
		{
			"description": "Fontsource variable fonts — move together",
			"groupName": "Fontsource",
			"matchPackageNames": [
				"@fontsource-variable/inter",
				"@fontsource-variable/jetbrains-mono",
				"@fontsource-variable/fraunces"
			]
		},
		{
			"description": "Octokit — GitHub API + webhook clients for the bot",
			"groupName": "Octokit",
			"matchPackageNames": ["@octokit/auth-app", "@octokit/rest", "@octokit/webhooks"]
		},
		{
			"description": "Observability stack — keep Grafana and Loki in sync",
			"groupName": "Observability stack",
			"matchManagers": ["docker-compose"],
			"matchPackageNames": ["grafana/grafana", "grafana/loki"]
		},
		{
			"description": "Dev utilities — miscellaneous root-level dev tooling",
			"groupName": "devDeps",
			"matchPackageNames": [
				"knip",
				"lint-staged",
				"simple-git-hooks",
				"sort-package-json",
				"del-cli",
				"npm-run-all2"
			]
		},
		{
			"description": "Major updates require explicit dashboard approval",
			"matchUpdateTypes": ["major"],
			"dependencyDashboardApproval": true
		},
		{
			"description": "GitHub Actions — pinned by digest, automerge non-major",
			"matchManagers": ["github-actions"],
			"matchUpdateTypes": ["minor", "patch", "digest"],
			"automerge": true,
			"automergeType": "pr",
			"automergeStrategy": "rebase"
		},
		{
			"description": "Dockerfile base images — keep digest-pinned",
			"matchManagers": ["dockerfile", "docker-compose"],
			"pinDigests": true
		},
		{
			"description": "Dockerfile/compose digest-only bumps (upstream rebuilds) — automerge",
			"matchManagers": ["dockerfile", "docker-compose"],
			"matchUpdateTypes": ["digest"],
			"automerge": true,
			"automergeType": "pr",
			"automergeStrategy": "rebase"
		},
		{
			"description": "Automerge non-major devDependencies after release-age window",
			"matchDepTypes": ["devDependencies"],
			"matchUpdateTypes": ["minor", "patch"],
			"automerge": true,
			"automergeType": "pr",
			"automergeStrategy": "rebase"
		}
	]
}
