{
	"name": "nexo",
	"version": "0.8.3",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo build",
		"build:auth": "turbo build --filter=@nexo/auth",
		"build:finance": "turbo build --filter=@nexo/finance",
		"build:landing": "turbo build --filter=@nexo/landing",
		"clean": "del '{apps,packages}/*/{build,dist,.svelte-kit,.turbo}' .turbo",
		"clean:deps": "del '{apps,packages}/*/node_modules' node_modules",
		"db:generate": "turbo db:generate --filter=@nexo/db",
		"db:migrate": "turbo db:migrate --filter=@nexo/db",
		"db:studio": "turbo db:studio --filter=@nexo/db",
		"dev": "turbo dev --filter=!@nexo/bot",
		"dev:auth": "turbo dev --filter=@nexo/auth",
		"dev:bot": "turbo dev --filter=@nexo/bot",
		"dev:finance": "turbo dev --filter=@nexo/finance",
		"dev:landing": "turbo dev --filter=@nexo/landing",
		"docker:db": "docker compose --profile production up postgres -d",
		"docker:down": "docker compose --profile production down",
		"docker:logs": "docker compose logs -f",
		"docker:up": "docker compose --profile production up --build",
		"docker:up:prod": "docker compose --profile server -f docker-compose.yml up -d --build",
		"docker:up:server": "docker compose --profile server up --build",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"knip": "knip",
		"lint": "turbo lint",
		"package:check": "sort-package-json --check \"{apps,packages}/*/package.json\" package.json",
		"package:format": "sort-package-json \"{apps,packages}/*/package.json\" package.json",
		"preview": "turbo preview",
		"qc": "run-s package:check format:check sync knip lint type:check build test",
		"sync": "pnpm --filter './apps/*' --filter '!@nexo/bot' exec svelte-kit sync",
		"test": "turbo test:unit",
		"test:e2e": "turbo test:e2e",
		"type:check": "turbo type:check"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"del-cli": "^7.0.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"knip": "^6.12.2",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"sort-package-json": "^3.6.1",
		"turbo": "^2.9.12",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11"
	},
	"packageManager": "pnpm@11.0.8+sha512.4c4097e1dd2d42372c4e7fa5a791ff28fc75a484c7ac192e64b1df0fdef17594ba982f9b4fed9adfb3c757846f565b799b2763fb3733d1de1bcb82cf46684912",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10.0.0"
	}
}
