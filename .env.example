# =============================================================================
# Nexo — environment variable reference
# =============================================================================
#
# HOW ENV FILES WORK IN THIS REPO
# --------------------------------
# SvelteKit has four env modules. This repo uses two of them:
#
#   $env/static/public   — baked into the bundle by Vite at build time.
#                          App versions are baked in via __APP_VERSION__ /
#                          __APP_VERSIONS__ defines (read from each app's
#                          package.json by vite.shared.ts and landing's
#                          vite.config.ts), not via this mechanism.
#
#   $env/dynamic/private — read from process.env at request time (runtime).
#                          All secrets (BETTER_AUTH_SECRET, DATABASE_URL, OAuth
#                          keys) use this. The built binary is environment-agnostic:
#                          the same Docker image works in staging and production,
#                          configured only by the environment it starts in.
#
# We do NOT use $env/static/private (bakes secrets into the bundle — wrong) or
# $env/dynamic/public (no benefit over static/public for known-at-build values).
#
# There are four separate contexts, each needing their own env file:
#
#   1. Docker (production-like)  →  .env                (repo root)
#      Read by docker-compose. Passed as runtime env to all containers.
#      DATABASE_URL uses the Docker service hostname "postgres".
#
#   2. Auth dev server           →  apps/auth/.env.local
#      Read by Vite/SvelteKit during `pnpm dev:auth`.
#      DATABASE_URL uses localhost:5433 (Docker-exposed port).
#
#   3. Finance dev server        →  apps/finance/.env.local
#      Read by Vite/SvelteKit during `pnpm dev:finance`.
#      DATABASE_URL uses localhost:5433 (Docker-exposed port).
#
#   4. Host CLI tools            →  .env.local           (repo root)
#      Overrides DATABASE_URL for drizzle-kit / db:migrate / db:studio,
#      which run on the host and need localhost, not "postgres".
#
# BETTER_AUTH_SECRET must be identical across all contexts — auth and
# finance both use it to sign/verify session tokens.
#
# =============================================================================


# =============================================================================
# 1. ROOT .env  (used by Docker / docker-compose)
# =============================================================================

# Postgres — must match POSTGRES_USER / POSTGRES_DB in docker-compose.yml
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgres://nexo:changeme@postgres:5432/nexo

# Better Auth — must be the same value in all apps
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=changeme

# OAuth providers (Google, GitHub, Discord developer console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# GitHub App (bot)
# Use the GitHub App's Client ID (e.g. `Iv23li…`), not the legacy numeric App ID.
# Find it on the app's About page: https://github.com/settings/apps/<your-app>
GH_CLIENT_ID=
GH_APP_PRIVATE_KEY=
GH_WEBHOOK_SECRET=
GH_REPO_OWNER=
GH_REPO_NAME=
GITHUB_TOKEN=

# Resend (email)
RESEND_API_KEY=

# Admin panel — email address granted access to the admin app
ADMIN_EMAIL=

# Grafana — admin password for the observability dashboard
# Generate with: openssl rand -hex 16
GRAFANA_PASSWORD=changeme

# Web Push (shared by all Nexo apps that send notifications)
# Generate with: pnpm exec web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@krieger2501.de

# Flaschen — Schichtangebot notifier
# Generate with: openssl rand -base64 32
FLASCHEN_TOKEN_ENC_KEY=
FLASCHEN_OAUTH_CLIENT_ID=86fe707f-ea47-4bf3-aa81-42579bf180cd
FLASCHEN_QUIET_HOURS=22-06
FLASCHEN_POLL_INTERVAL_MS=180000
FLASCHEN_POLL_JITTER_MS=30000
FLASCHEN_API_TZ_MODE=local-naive


# =============================================================================
# 2. apps/auth/.env.local  (used by SvelteKit dev server for auth app)
# =============================================================================
#
# DATABASE_URL=postgres://nexo:changeme@localhost:5433/nexo
# BETTER_AUTH_SECRET=<same value as root .env>
# PUBLIC_AUTH_URL=http://localhost:3001
# FINANCE_URL=http://localhost:3002
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=


# =============================================================================
# 3. apps/finance/.env.local  (used by SvelteKit dev server for finance app)
# =============================================================================
#
# DATABASE_URL=postgres://nexo:changeme@localhost:5433/nexo
# BETTER_AUTH_SECRET=<same value as root .env>
# PUBLIC_AUTH_URL=http://localhost:3001


# =============================================================================
# 4. apps/flaschen/.env.local  (used by SvelteKit dev server for flaschen app)
# =============================================================================
#
# DATABASE_URL=postgres://nexo:changeme@localhost:5433/nexo
# BETTER_AUTH_SECRET=<same value as root .env>
# PUBLIC_AUTH_URL=http://localhost:3001
# PUBLIC_FLASCHEN_URL=http://localhost:3006
#
# # Same VAPID keypair as root .env — the public one is also exposed to the browser
# PUBLIC_VAPID_PUBLIC_KEY=<same as VAPID_PUBLIC_KEY>
# VAPID_PUBLIC_KEY=<same as root .env>
# VAPID_PRIVATE_KEY=<same as root .env>
# VAPID_SUBJECT=mailto:dev@localhost
#
# FLASCHEN_TOKEN_ENC_KEY=<same as root .env>
# FLASCHEN_OAUTH_CLIENT_ID=86fe707f-ea47-4bf3-aa81-42579bf180cd


# =============================================================================
# 5. apps/landing/.env.local  (used by SvelteKit dev server for landing app)
# =============================================================================
#
# DATABASE_URL=postgres://nexo:changeme@localhost:5433/nexo
# BETTER_AUTH_SECRET=<same value as root .env>
# PUBLIC_AUTH_URL=http://localhost:3001
# PUBLIC_FINANCE_URL=http://localhost:3002
# PUBLIC_FLASCHEN_URL=http://localhost:3006
# PUBLIC_ADMIN_URL=http://localhost:3000
# PUBLIC_LANDING_URL=http://localhost:3003


# =============================================================================
# ROOT .env.local  (overrides for host-side CLI tools — drizzle-kit etc.)
# =============================================================================
#
# DATABASE_URL=postgres://nexo:changeme@localhost:5433/nexo


# =============================================================================
# QUICK SETUP
# =============================================================================
#
# 1. Copy this file:       cp .env.example .env
# 2. Set POSTGRES_PASSWORD and BETTER_AUTH_SECRET (openssl rand -hex 32)
# 3. Fill in OAuth provider IDs/secrets from each developer console
# 4. Create apps/auth/.env.local, apps/finance/.env.local, and
#    apps/landing/.env.local as shown above
# 5. Create .env.local at repo root with the localhost DATABASE_URL
# 6. Start the database:   pnpm docker:db
# 7. Run migrations:       pnpm db:migrate
# 8. Start dev servers:    pnpm dev
