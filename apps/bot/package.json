{
	"name": "@nexo/bot",
	"version": "0.4.0",
	"private": true,
	"type": "module",
	"files": [
		"dist",
		"package.json"
	],
	"scripts": {
		"build": "tsc",
		"dev": "node --watch src/index.ts",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"qc": "run-s lint type:check build",
		"start": "node dist/index.js",
		"type:check": "tsc --noEmit"
	},
	"dependencies": {
		"@nexo/logger": "workspace:*",
		"@octokit/auth-app": "^8.2.0",
		"@octokit/rest": "^22.0.1",
		"@octokit/webhooks": "^14.2.0"
	},
	"devDependencies": {
		"@types/node": "catalog:"
	},
	"engines": {
		"node": ">=24.0.0"
	}
}
