{
	"name": "@nexo/bot",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc",
		"dev": "node --watch src/index.ts",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"knip": "knip",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"package:check": "sort-package-json --check",
		"package:format": "sort-package-json",
		"qc": "run-s package:check format:check lint knip type:check build",
		"start": "node dist/index.js",
		"type:check": "tsc --noEmit"
	},
	"dependencies": {
		"@octokit/auth-app": "^7.2.2",
		"@octokit/rest": "^21.1.1",
		"@octokit/webhooks": "^13.9.1"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@types/node": "^22.19.17",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"knip": "^6.12.1",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.3",
		"sort-package-json": "^3.6.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2"
	},
	"engines": {
		"node": ">=24.0.0"
	}
}
