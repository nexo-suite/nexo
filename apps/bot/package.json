{
	"name": "@nexo/bot",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "tsc",
		"dev": "node --watch src/index.ts",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"qc": "run-s lint type:check build",
		"start": "node dist/index.js",
		"type:check": "tsc --noEmit"
	},
	"dependencies": {
		"@nexo/logger": "workspace:*",
		"@octokit/auth-app": "^7.2.2",
		"@octokit/rest": "^21.1.1",
		"@octokit/webhooks": "^13.9.1"
	},
	"devDependencies": {
		"@types/node": "catalog:"
	},
	"engines": {
		"node": ">=24.0.0"
	}
}
