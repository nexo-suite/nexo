{
	"name": "@nexo/admin",
	"version": "0.10.0",
	"private": true,
	"type": "module",
	"files": [
		"build",
		"package.json"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --port 3004",
		"lint": "eslint \"**/*.svelte\"",
		"lint:fix": "eslint \"**/*.svelte\" --fix",
		"preview": "vite preview",
		"qc": "run-s lint type:check build",
		"translate": "pnpm dlx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"translate:watch": "pnpm dlx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --watch",
		"type:check": "svelte-kit sync && svelte-check-native --tsconfig ./tsconfig.json",
		"type:check:watch": "svelte-kit sync && svelte-check-native --tsconfig ./tsconfig.json --watch"
	},
	"dependencies": {
		"@lucide/svelte": "catalog:",
		"@nexo/db": "workspace:*",
		"@nexo/email": "workspace:*",
		"@nexo/errors": "workspace:*",
		"@nexo/i18n": "workspace:*",
		"@nexo/logger": "workspace:*",
		"@nexo/push": "workspace:*",
		"@nexo/security": "workspace:*",
		"@nexo/ui": "workspace:*",
		"better-auth": "catalog:",
		"drizzle-orm": "catalog:",
		"workbox-precaching": "catalog:"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "catalog:",
		"@sveltejs/adapter-node": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"@vite-pwa/sveltekit": "catalog:",
		"svelte": "catalog:",
		"svelte-check-native": "catalog:",
		"tailwindcss": "catalog:",
		"vite": "catalog:"
	}
}
