{
	"name": "@nexo/landing",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --port 3000",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"knip": "knip",
		"package:check": "sort-package-json --check",
		"package:format": "sort-package-json",
		"preview": "vite preview",
		"qc": "run-s package:check format:check knip type:check build",
		"type:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"type:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^22.19.17",
		"knip": "^6.12.1",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"sort-package-json": "^3.6.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.11"
	}
}
