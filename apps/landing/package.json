	},
	"dependencies": {
		"@nexo/db": "workspace:*",
		"@nexo/ui": "workspace:*",
		"better-auth": "^1.6.10",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.18.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "catalog:",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"vite": "^8.0.11"
	}
