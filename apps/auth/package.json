{
	"name": "@nexo/auth",
	"version": "0.4.0",
	"private": true,
	"type": "module",
	"files": [
		"build",
		"package.json"
	],
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --port 3001",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"preview": "vite preview",
		"qc": "run-s lint type:check build",
		"translate": "pnpm dlx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"translate:watch": "pnpm dlx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --watch",
		"type:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"type:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"dependencies": {
		"@better-auth/oauth-provider": "^1.6.11",
		"@nexo/db": "workspace:*",
		"@nexo/logger": "workspace:*",
		"@nexo/security": "workspace:*",
		"@nexo/ui": "workspace:*",
		"better-auth": "^1.6.11",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.18.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "catalog:",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"vite": "^8.0.13"
	}
}
