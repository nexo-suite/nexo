{
	"name": "@nexo/finance",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --port 3002",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"knip": "knip",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"package:check": "sort-package-json --check",
		"package:format": "sort-package-json",
		"preview": "vite preview",
		"qc": "run-s package:check format:check lint knip type:check build test:unit",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"type:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"type:check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"dependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@nexo/db": "workspace:*",
		"better-auth": "^1.6.9",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"lucide-svelte": "^1.0.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.2.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^24.12.2",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/coverage-v8": "^4.1.5",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"happy-dom": "^20.9.0",
		"knip": "^6.12.1",
		"npm-run-all2": "^8.0.4",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"sort-package-json": "^3.6.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10.0.0"
	}
}
